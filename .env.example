# Bilads — environment variables
# Copy to .env.local and fill in real values. NEVER commit .env.local (see .gitignore).
#   cp .env.example .env.local

# ─────────────────────────────────────────────────────────────────────────────
# GMI Cloud — LLM + image generation (REQUIRED)
# OpenAI-compatible API. Used by lib/gmi.ts for the 3 agents + ad image gen.
# Get the key, base URL, and model IDs from the GMI Cloud playground (Phase 0).
# ─────────────────────────────────────────────────────────────────────────────
GMI_API_KEY=
# OpenAI-compatible endpoint, e.g. https://api.gmi-serving.com/v1 (confirm in playground)
GMI_BASE_URL=
# Chat/vision model ID for Researcher, Media Buyer, Creative Director
GMI_CHAT_MODEL=
# Image model ID for the wide-format (1024x512) ad art
GMI_IMAGE_MODEL=

# ─────────────────────────────────────────────────────────────────────────────
# Nimble — live market intelligence (SPONSOR, optional)
# Feeds data/nimble-signals/. Without it the pre-generated Places-derived
# signals are used (see scripts/gen-nimble-signals.mjs).
# ─────────────────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# InsForge — campaign / creative / agent-run storage (SPONSOR, optional)
# Backend persistence for campaigns, generated creatives, and agent logs.
# ─────────────────────────────────────────────────────────────────────────────
INSFORGE_API_KEY=
INSFORGE_BASE_URL=
INSFORGE_PROJECT_ID=
