# Bilads — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# BAND — live five-agent collaboration room (SPONSOR)
# Register five sibling External Agents at https://app.band.ai/agents and put
# each API key (shown once at creation) below. Local fallback is used if blank.
# ─────────────────────────────────────────────────────────────────────────────
BAND_API_BASE_URL=https://app.band.ai/api/v1/agent
BAND_MARKET_RESEARCH_API_KEY=
BAND_MEDIA_PLANNER_API_KEY=
BAND_CREATIVE_DIRECTOR_API_KEY=
BAND_PERFORMANCE_ANALYST_API_KEY=
BAND_RISK_BRAND_API_KEY=

# Copy to app/.env.local (the Next.js app reads env from app/) and fill in real
# values. NEVER commit .env.local (see .gitignore).
#   cp .env.example app/.env.local

# ─────────────────────────────────────────────────────────────────────────────
# GMI Cloud — LLM + image generation (REQUIRED)
# Chat: OpenAI-compatible cluster at GMI_BASE_URL.
# Images: separate async request-queue API (GMI_MEDIA_URL, default in gmi.ts).
# Model IDs confirmed live 2026-07-13:
#   google/gemini-3.5-flash — ~2.6s chat, clean strict JSON, vision-capable
#   gemini-3.1-flash-image  — ~17s/image via request queue; 16:9 (2:1 rejected)
# ─────────────────────────────────────────────────────────────────────────────
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_CHAT_MODEL=google/gemini-3.5-flash
GMI_VISION_MODEL=google/gemini-3.5-flash
GMI_IMAGE_MODEL=gemini-3.1-flash-image
# Optional override; defaults to the console request-queue endpoint in gmi.ts
# GMI_MEDIA_URL=https://console.gmicloud.ai/api/v1/ie/requestqueue/apikey/requests

# ─────────────────────────────────────────────────────────────────────────────
# Nimble — live market intelligence (SPONSOR, optional)
# Falls back to the pre-generated data/nimble-signals dataset when unset.
# ─────────────────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Google Street View — campaign simulation background (optional)
# Used by /api/streetview to composite generated ads into the real street scene.
# GOOGLE_STREET_VIEW_API_KEY takes precedence if both values are set.
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_STREET_VIEW_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# InsForge — campaign / creative / agent-run storage (SPONSOR, optional)
# Falls back to the in-memory store when the base URL or API key is unset.
# ─────────────────────────────────────────────────────────────────────────────
INSFORGE_BASE_URL=
INSFORGE_API_KEY=
INSFORGE_PROJECT_ID=
