# Bilads — environment variables
# Copy to app/.env.local (the Next.js app reads env from app/) and fill in real
# values. NEVER commit .env.local (see .gitignore).
#   cp .env.example app/.env.local

# ─────────────────────────────────────────────────────────────────────────────
# GMI Cloud — LLM + image generation (REQUIRED)
# OpenAI-compatible API used by the agents and ad image generation.
# ─────────────────────────────────────────────────────────────────────────────
GMI_API_KEY=
GMI_BASE_URL=https://api.gmi-serving.com/v1
GMI_CHAT_MODEL=deepseek-ai/DeepSeek-V3
GMI_IMAGE_MODEL=gemini-3.1-flash-image

# ─────────────────────────────────────────────────────────────────────────────
# Nimble — live market intelligence (SPONSOR, optional)
# Falls back to the pre-generated data/nimble-signals dataset when unset.
# ─────────────────────────────────────────────────────────────────────────────
NIMBLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# InsForge — campaign / creative / agent-run storage (SPONSOR, optional)
# Falls back to the in-memory store when the base URL or API key is unset.
# ─────────────────────────────────────────────────────────────────────────────
INSFORGE_BASE_URL=
INSFORGE_API_KEY=
INSFORGE_PROJECT_ID=
