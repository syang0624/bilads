# Copy to .env.local and fill in. NEVER commit .env.local (already gitignored).

# --- GMI Cloud (OpenAI-compatible) -----------------------------------------
# API key from the GMI Cloud console (Godson has the org account).
GMI_API_KEY=
# Base URL of GMI's OpenAI-compatible inference API.
GMI_BASE_URL=https://api.gmi-serving.com/v1
# Model IDs come from Godson — confirm in the GMI playground before the demo.
GMI_CHAT_MODEL=deepseek-ai/DeepSeek-V3
GMI_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# --- InsForge (backend infrastructure) --------------------------------------
# Leave blank to run fully offline with the in-memory fallback store.
INSFORGE_BASE_URL=
INSFORGE_API_KEY=
